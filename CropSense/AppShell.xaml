<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CropSense.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CropSense.Views"
    Title="CropSense"
    Shell.TabBarForegroundColor="#39FF14"
    Shell.BackgroundColor="#141400"
    Shell.TabBarUnselectedColor="#41433b"
    Shell.TabBarTitleColor="#39FF14">

    <TabBar>
        <ShellContent
            x:Name="HomeTab"
            Title="Home"
            Icon="monitorplant.png"
            Route="home"
            ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent
            x:Name="CropsTab"
            Title="Crops"
            Icon="bell.png"
            Route="crop-view"
            ContentTemplate="{DataTemplate views:CropViewPage}" />
        <ShellContent
            x:Name="ScanTab"
            Title="Scan"
            Icon="camera.png"
            Route="capture"
            ContentTemplate="{DataTemplate views:CapturePage}" />
        <ShellContent
            x:Name="ProfileTab"
            Title="Profile"
            Icon="user.png"
            Route="settings"
            ContentTemplate="{DataTemplate views:ResultPage}" />
    </TabBar>

</Shell>
