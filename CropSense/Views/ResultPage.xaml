<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CropSense.Views.ResultPage"
             Shell.NavBarIsVisible="False"
             Title="Result">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Image Source="screens3.png" Aspect="AspectFit" HorizontalOptions="Fill" />
            <Label Text="{Binding PredictionLabel}" Style="{StaticResource Headline}" />
            <Label Text="A leaf spot fungus" Style="{StaticResource SubHeadline}" />
            <Label Text="{Binding Confidence}" />
            <Label Text="{Binding Severity}" />
            <Label Text="{Binding TreatmentRecommendation}" />
            <HorizontalStackLayout Spacing="10">
                <Button Text="Treatment" Clicked="OnTreatmentClicked" />
                <Button Text="Prevention" Clicked="OnPreventionClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
